# COMS Production Environment Configuration
# Copy this file to .env.production and fill in the values
# DO NOT commit .env.production to version control!

# Django Settings
SECRET_KEY=your-very-long-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-vps-ip
DJANGO_SETTINGS_MODULE=config.settings

# Database Configuration
POSTGRES_DB=coms_production
POSTGRES_USER=coms_user
POSTGRES_PASSWORD=your-strong-database-password-here
DATABASE_URL=postgresql://coms_user:your-strong-database-password-here@db:5432/coms_production

# Redis Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email Configuration (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=COMS System <noreply@your-domain.com>

# AWS S3 Configuration (Optional - for file storage)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=coms-media-production
AWS_S3_REGION_NAME=us-east-1

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# CORS Settings
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOW_CREDENTIALS=True

# Logging
LOG_LEVEL=INFO

# Sentry (Optional - for error tracking)
SENTRY_DSN=your-sentry-dsn-here

# Application Settings
SITE_NAME=COMS - Construction Operations Management System
SITE_URL=https://your-domain.com

# File Upload Limits
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# Session Configuration
SESSION_COOKIE_AGE=86400  # 24 hours

# JWT Configuration
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Celery Configuration
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=300

# Report Generation
REPORT_CACHE_DURATION=600  # 10 minutes

# Database Connection Pool
DB_CONN_MAX_AGE=600
