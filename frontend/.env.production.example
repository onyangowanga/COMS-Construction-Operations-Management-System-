# Frontend Production Environment Variables
# Copy this file to .env.production when deploying
# These variables are embedded at build time (NEXT_PUBLIC_* prefix required for client-side access)

# API Configuration
NEXT_PUBLIC_API_URL=http://your-domain.com/api
NEXT_PUBLIC_WS_URL=ws://your-domain.com/ws

# Application Settings
NEXT_PUBLIC_APP_NAME=COMS
NEXT_PUBLIC_APP_VERSION=1.0.0

# Token Expiration (in seconds)
NEXT_PUBLIC_ACCESS_TOKEN_EXPIRE=86400        # 24 hours
NEXT_PUBLIC_REFRESH_TOKEN_EXPIRE=604800      # 7 days

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=false

# Build Configuration
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
