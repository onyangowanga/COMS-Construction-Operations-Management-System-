    def get_project_role(self, project_id):
    
    Note: Permission logic has been moved to services.py for better maintainability.
    """d permissions.
    Allows users to have different roles across different projects.
    """
    
    class ProjectRole(models.TextChoices):
        """Project-specific role definitions"""
        OWNER = 'OWNER', _('Project Owner')
        MANAGER = 'MANAGER', _('Project Manager')
        SITE_MANAGER = 'SITE_MANAGER', _('Site Manager')
        QS = 'QS', _('Quantity Surveyor')
        ARCHITECT = 'ARCHITECT', _('Architect')
        FOREMAN = 'FOREMAN', _('Foreman')
        VIEWER = 'VIEWER', _('Viewer (Read-only)')
    
    user = models.ForeignKey(
        User,
        on_delete=models.CASCADE,
        related_name='project_access',
        help_text=_("User with project access")
    )
    
    project = models.ForeignKey(
        'projects.Project',  # Forward reference to avoid circular import
        on_delete=models.CASCADE,
        related_name='members',
        help_text=_("Project being accessed")
    )
    
    project_role = models.CharField(
        max_length=20,
        choices=ProjectRole.choices,
        default=ProjectRole.VIEWER,
        help_text=_("User's role within this project")
    )
    
    # Permissions
    can_edit = models.BooleanField(
        default=False,
        help_text=_("Can edit project details")
    )
    
    can_manage_budget = models.BooleanField(
        default=False,
        help_text=_("Can manage project budget and expenses")
    )
    
    can_manage_workers = models.BooleanField(
        default=False,
        help_text=_("Can manage workers and attendance")
    )
    
    can_approve_documents = models.BooleanField(
        default=False,
        help_text=_("Can approve documents and valuations")
    )
    
    can_view_financials = models.BooleanField(
        default=True,
        help_text=_("Can view financial information")
    )
    
    # Status
    is_active = models.BooleanField(
        default=True,
        help_text=_("Access is currently active")
    )
    
    # Audit fields
    assigned_by = models.ForeignKey(
        User,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name='assigned_accesses',
        help_text=_("User who granted this access")
    )
    
    assigned_at = models.DateTimeField(auto_now_add=True)
    removed_at = models.DateTimeField(blank=True, null=True)
    notes = models.TextField(blank=True, help_text=_("Notes about this access grant"))
    
    class Meta:
        db_table = 'project_access'
        verbose_name = _('Project Access')
        verbose_name_plural = _('Project Access')
        unique_together = [['user', 'project']]
        ordering = ['-assigned_at']
        indexes = [
            models.Index(fields=['user', 'project']),
            models.Index(fields=['project', 'is_active']),
            models.Index(fields=['project_role']),
        ]
